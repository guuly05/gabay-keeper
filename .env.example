# OPENROUTER_API_KEY: Required only on your backend/proxy for OpenRouter API calls.
# Never expose this as a VITE_ variable because Vite embeds those values in browser bundles.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for the HTTP-Referer header when calling OpenRouter.
APP_URL="MY_APP_URL"
